/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.semanticscholar.org https://api.openalex.org https://export.arxiv.org; frame-ancestors 'none'; base-uri 'self'; form-action 'none'

/data/*
  Cache-Control: public, max-age=86400, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
